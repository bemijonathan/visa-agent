# Database (PostgreSQL)
DATABASE_URL="postgresql://visa_agent:visa_agent_dev@localhost:5432/visa_agent"

# Firebase Auth
# For production: provide service account JSON (download from Firebase Console)
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"your-project",...}'

# For development with emulator: set this instead of FIREBASE_SERVICE_ACCOUNT
FIREBASE_AUTH_EMULATOR_HOST="localhost:9099"

# Google AI (Gemini — form filling, letter generation, OCR)
GOOGLE_AI_API_KEY="..."

# Cloudinary (document storage)
CLOUDINARY_CLOUD_NAME="..."
CLOUDINARY_API_KEY="..."
CLOUDINARY_API_SECRET="..."

# Qdrant (vector DB — not currently in use, reserved for future RAG)
QDRANT_URL="http://localhost:6333"

# Server
PORT=3001
NODE_ENV=development

# CORS — set these in production
DASHBOARD_URL=http://localhost:5173
CHROME_EXTENSION_ID=  # Your extension ID from chrome://extensions (leave blank in dev)
