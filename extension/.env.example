# Backend API URL
VITE_API_URL=http://localhost:3001

# Dashboard URL (used for the "Open Dashboard" link in the sidepanel)
VITE_DASHBOARD_URL=http://localhost:5173

# Firebase Authentication
# For production: get these from Firebase Console > Project Settings
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id

# Google OAuth Client ID (for chrome.identity)
# Create at Google Cloud Console > APIs & Services > Credentials
VITE_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# For development: emulator is enabled by default
# Set to "false" to disable emulator and use real Firebase
# VITE_USE_FIREBASE_EMULATOR=false
