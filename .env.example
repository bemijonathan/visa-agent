# Root environment reference
# Copy to .env and fill in values
# Each package also has its own .env.example with more detail

# === Docker Services ===
# Start with: docker compose up -d

# === Firebase Emulator ===
# Auth emulator runs on http://localhost:9099
# Emulator UI available at http://localhost:4000

# === Backend .env ===
# FIREBASE_AUTH_EMULATOR_HOST="localhost:9099"

# === Dashboard/Extension .env ===
# Emulator enabled by default in dev mode
# VITE_USE_FIREBASE_EMULATOR="false"  # Set to disable emulator
